workspace = join_path([env("TMPDIR") or "/tmp", "vibelang-yaml-example"])
make_dir(workspace)
path = join_path([workspace, "config.yaml"])
defer delete_file(path)

write_yaml(path, {"name": "Ada", "enabled": true, "ports": [8080, 8081]})
payload = read_yaml(path)
parsed = yaml_parse("service: vibelang\nports:\n  - 7000\n  - 7001\n")

print(payload["name"])
print(payload["ports"][0])
print(parsed["service"])
print(contains(yaml_stringify(payload), "enabled: true"))
